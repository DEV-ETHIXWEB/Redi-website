---
import type { Partner } from '@/types/wordpress';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Icon from '@/components/ui/Icon.astro';

export interface Props {
  eyebrow: string;
  heading: string;
  partners: Partner[];
}

const { eyebrow, heading, partners } = Astro.props;
---

<section class="bg-steel-100 py-14 sm:py-20 md:py-24">
  <div class="container-page">
    <SectionHeading eyebrow={eyebrow} heading={heading} align="center" />

    <ul class="mt-12 grid gap-7 md:grid-cols-2" role="list">
      {
        partners.map((partner, index) => (
          <li class="reveal" style={`--reveal-delay: ${index * 80}ms`}>
            <article class="group shadow-soft hover:shadow-lifted overflow-hidden rounded-xl transition-all duration-300 ease-out hover:-translate-y-1.5">
              {partner.variant === 'photo' ? (
                <div class="relative aspect-[2036/492] overflow-hidden">
                  <img
                    src={partner.image.url}
                    alt={partner.image.alt}
                    width="1200"
                    height="290"
                    loading="lazy"
                    decoding="async"
                    class="size-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                  />
                </div>
              ) : (
                <div class="from-navy-700 to-navy-900 relative flex aspect-[2036/492] items-center justify-center overflow-hidden bg-gradient-to-b">
                  <svg
                    aria-hidden="true"
                    viewBox="0 0 400 100"
                    preserveAspectRatio="xMidYMid slice"
                    class="pointer-events-none absolute inset-0 size-full opacity-[0.14]"
                  >
                    <g fill="none" stroke="white" stroke-width="1.5">
                      <path d="M170 2 L232 34 L170 66 L108 34 Z" />
                      <path d="M170 34 L232 66 L170 98 L108 66 Z" />
                    </g>
                  </svg>
                  <p class="font-body relative text-3xl font-semibold text-white">
                    {partner.headline}
                  </p>
                </div>
              )}
              <div class="bg-steel-200 flex items-center gap-2 px-5 py-4">
                {partner.variant === 'wordmark' ? (
                  <img
                    src={partner.image.url}
                    alt={partner.name}
                    width="216"
                    height="60"
                    loading="lazy"
                    decoding="async"
                    class="h-6 w-auto brightness-0 [filter:brightness(0)_opacity(0.75)]"
                  />
                ) : (
                  <span class="font-body text-navy-700 text-xl font-bold">
                    Location<span class="text-navy-950 font-extrabold">One</span>
                  </span>
                )}
              </div>
              <div class="bg-steel-200 flex items-center gap-1.5 px-5 pb-4">
                <Icon name="external-link" size={14} class="text-ink-600" />
                <a
                  href={partner.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-navy-700 text-ink-600 text-sm underline underline-offset-2 transition-colors"
                >
                  {new URL(partner.url).hostname.replace('www.', '')}
                </a>
              </div>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>
